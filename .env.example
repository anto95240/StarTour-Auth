# Environment
NODE_ENV=development

# Server
PORT=3001
AUTH_SERVICE_PORT=3001

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=startour_auth_db

# JWT
